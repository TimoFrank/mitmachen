FROM nginx:1.27-alpine

COPY demo/ /usr/share/nginx/html/
COPY map/ /usr/share/nginx/html/map/
COPY login/auth-config.js /usr/share/nginx/html/login/auth-config.js
COPY login/auth-guard.js /usr/share/nginx/html/login/auth-guard.js
COPY data/demo-data.js /usr/share/nginx/html/data/demo-data.js
COPY data/supabase-config.js /usr/share/nginx/html/data/supabase-config.js
COPY data/versorgungs-kompass-data.js /usr/share/nginx/html/data/versorgungs-kompass-data.js
COPY public/ /usr/share/nginx/html/public/
COPY nginx.demo.conf /etc/nginx/conf.d/default.conf

EXPOSE 8080
