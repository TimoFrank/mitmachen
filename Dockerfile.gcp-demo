FROM node:22-alpine

WORKDIR /app

COPY package.json package-lock.json ./
RUN npm ci --omit=dev

COPY data ./data
COPY demo ./demo
COPY app ./app
COPY gcp ./gcp
COPY login ./login
COPY map ./map
COPY mitmachen ./mitmachen
COPY public ./public

ENV NODE_ENV=production
ENV PORT=8080

EXPOSE 8080

CMD ["node", "gcp/server.mjs"]
