# GitHub Environment variables for `pre-gematik`.
# Copy names and resolved Terraform outputs into GitHub Settings > Environments.
# This file contains no secret. Never add DB_PASSWORD or a service-account JSON key.

GCP_PROJECT_ID=example-pre-gematik-project
GCP_REGION=europe-west3
GKE_CLUSTER_NAME=versorgungs-kompass-pre-gematik
GKE_LOCATION=europe-west3
WIF_PROVIDER=projects/123456789012/locations/global/workloadIdentityPools/github-pre-gematik/providers/github-actions
DEPLOYER_SERVICE_ACCOUNT=github-pre-gematik-deployer@example-pre-gematik-project.iam.gserviceaccount.com
GAR_REPOSITORY=europe-west3-docker.pkg.dev/example-pre-gematik-project/versorgungs-kompass-pre-gematik

API_BASE_URL=https://pre-gematik.example.invalid
FRONTEND_BASE_URL=https://pre-gematik.example.invalid
FRONTEND_BUCKET=example-pre-gematik-frontend

DB_NAME=versorgungs_kompass
DB_USER=vk_app
DB_PASSWORD_SECRET_NAME=vk-pre-gematik-postgres-password
IAP_OAUTH_BOOTSTRAP_SECRET_NAME=vk-pre-gematik-iap-oauth-bootstrap

PROFILE_IMAGE_BUCKET=example-pre-gematik-profiles
CONTACT_IMAGE_BUCKET=example-pre-gematik-contacts
CONTACT_NOTE_ATTACHMENT_BUCKET=example-pre-gematik-attachments
STAKEHOLDER_LOGO_BUCKET=example-pre-gematik-stakeholder-logos
CLOUD_SQL_INSTANCE_CONNECTION_NAME=example-pre-gematik-project:europe-west3:vk-pre-gematik-postgres
GKE_INGRESS_IP_NAME=vk-pre-gematik-api
K8S_NAMESPACE=pre-gematik
IAP_OAUTH_CLIENT_CREDENTIALS_SECRET_NAME=versorgungs-kompass-iap-oauth
IAP_RESOURCE_ACCESS_GROUP=group:pre-gematik-access@example.invalid
