# Local operator configuration for a controlled pre-gematik migration.
# Never copy these values into GitHub Environment variables and never commit a
# resolved copy. Set credentials only in a protected, short-lived shell/session.

# Read-only GCP context and concrete pre-import backup gate.
GCP_PROJECT_ID=example-pre-gematik-project
GCP_REGION=europe-west3
GKE_CLUSTER_NAME=versorgungs-kompass-pre-gematik
GKE_LOCATION=europe-west3
K8S_NAMESPACE=pre-gematik
CLOUD_SQL_INSTANCE_CONNECTION_NAME=example-pre-gematik-project:europe-west3:vk-pre-gematik-postgres
PRE_GEMATIK_GCP_PROJECT_SHA256=sha256:REPLACE_WITH_INDEPENDENTLY_APPROVED_64_HEX_DIGEST
PRE_GEMATIK_DATA_BUCKET_IAM_SHA256=sha256:REPLACE_WITH_INDEPENDENTLY_APPROVED_64_HEX_DIGEST
PRE_IMPORT_BACKUP_ID=REPLACE_WITH_CONCRETE_SUCCESSFUL_BACKUP_ID
# Optional lower time bound for the concrete backup, in ISO-8601 format.
# PRE_IMPORT_BACKUP_NOT_BEFORE=2026-07-20T00:00:00.000Z

# Pinned official Cloud SQL Auth Proxy used and started by the Apply tools.
# Resolve symlinks and approve the binary digest independently before the run.
CLOUD_SQL_AUTH_PROXY_EXECUTABLE=/absolute/path/to/cloud-sql-proxy
CLOUD_SQL_AUTH_PROXY_SHA256=sha256:REPLACE_WITH_INDEPENDENTLY_APPROVED_64_HEX_DIGEST
# Unset means the existing local sql-data path. Only the dedicated, short-lived
# GKE migration Job sets this exact value; all other values fail closed.
# CLOUD_SQL_AUTH_PROXY_CONNECT_MODE=private-ip

# Database migration connections and independent source/target pins.
SOURCE_DATABASE_URL='postgresql://migration_reader.example-supabase-project-ref:REPLACE_IN_PROTECTED_SESSION@aws-0-eu-central-1.pooler.supabase.com:5432/postgres?sslmode=verify-full&sslrootcert=/absolute/protected/path/supabase-ca.crt'
# Credential template only: on Apply the tool ignores this loopback port and
# creates a private Unix socket through its own instance-bound Auth Proxy.
TARGET_DATABASE_URL='postgresql://migration_admin:REPLACE_IN_PROTECTED_SESSION@127.0.0.1:5432/versorgungs_kompass?sslmode=disable'
EXPECTED_SOURCE_PROJECT_ID=example-supabase-project-ref
EXPECTED_TARGET_PROJECT_ID=example-pre-gematik-project
EXPECTED_STORAGE_PROJECT_PAIR_SHA256=sha256:REPLACE_WITH_INDEPENDENTLY_APPROVED_64_HEX_DIGEST
EXPECTED_TARGET_DATABASE_NAME=versorgungs_kompass
STORAGE_MIGRATION_MANIFEST_PATH=/absolute/protected/path/storage-migration-manifest.json
STORAGE_MIGRATION_RECOVERY_JOURNAL_PATH=/absolute/protected/path/storage-migration-recovery.ndjson
# Optional target-only remediation bundle. Both paths are required together;
# inputs must remain owner-only and outside the repository.
# LOGO_REMEDIATION_MANIFEST_PATH=/absolute/protected/path/logo-remediation-preview.json
# LOGO_REMEDIATION_OBJECT_DIRECTORY=/absolute/protected/path/logo-remediation-objects
# The GKE migration operator accepts only these fixed staged paths instead:
# LOGO_REMEDIATION_MANIFEST_PATH=/protected-input/run/logo-remediation-preview.json
# LOGO_REMEDIATION_OBJECT_DIRECTORY=/protected-input/run/logo-remediation-objects
TARGET_PROFILE_IMAGE_BUCKET=example-pre-gematik-profiles
TARGET_CONTACT_IMAGE_BUCKET=example-pre-gematik-contacts
TARGET_CONTACT_NOTE_ATTACHMENT_BUCKET=example-pre-gematik-attachments
TARGET_STAKEHOLDER_LOGO_BUCKET=example-pre-gematik-stakeholder-logos

# Storage migration. Replace credentials only in the protected operator session.
SUPABASE_URL=https://example-supabase-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=REPLACE_IN_PROTECTED_SESSION
GOOGLE_OAUTH_ACCESS_TOKEN=REPLACE_IN_PROTECTED_SESSION
PROFILE_IMAGE_BUCKET=example-pre-gematik-profiles
CONTACT_IMAGE_BUCKET=example-pre-gematik-contacts
CONTACT_NOTE_ATTACHMENT_BUCKET=example-pre-gematik-attachments
STAKEHOLDER_LOGO_BUCKET=example-pre-gematik-stakeholder-logos

# Post-import IAP identity-binding administration.
PRE_GEMATIK_IDENTITY_ADMIN_DATABASE_URL='postgresql://identity_admin:REPLACE_IN_PROTECTED_SESSION@127.0.0.1:5432/versorgungs_kompass?sslmode=disable'
PRE_GEMATIK_IDENTITY_TARGET_SHA256=sha256:REPLACE_WITH_INDEPENDENTLY_APPROVED_64_HEX_DIGEST
